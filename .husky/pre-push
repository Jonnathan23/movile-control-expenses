localBranchName=$(git rev-parse --abbrev-ref HEAD)
validBranchRegex="^(production|develop|epic\/[a-z-]+|(feat|fix|docs|style|refactor|chore)\/[a-z-]+)$"

# Ignorar si estamos en un estado de 'detached HEAD'
if [ "$localBranchName" = "HEAD" ]; then
    exit 0
fi

if ! echo "$localBranchName" | grep -Eq "$validBranchRegex"; then
    echo "Error: Nombre de rama inválido '$localBranchName'"
    echo "Los nombres de las ramas deben seguir el estándar:"
    echo "  - epic/nombre-del-modulo"
    echo "  - type/modulo-funcionalidad (ejemplo: feat/admin-desk-login)"
    exit 1
fi