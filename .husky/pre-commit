#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

stagedFilesCount=$(git diff --cached --numstat | wc -l)
maximumAllowedFiles=10

if [ "$stagedFilesCount" -gt "$maximumAllowedFiles" ]; then
    echo "Error: estás intentando hacer commit de $stagedFilesCount archivos."
    echo "Por favor, mantén los commits en menos de $maximumAllowedFiles archivos para mantener un historial limpio."
    exit 1
fi

echo "Auditando la estructura de archivos..."
echo "Validando reglas de arquitectura y dependencias..."
# 1. Ejecutar ls-lint
if command -v bun >/dev/null 2>&1; then
    bun run ls-lint
else
    pnpm exec ls-lint
fi

echo "Ejecutando validaciones de código (Lint-staged)..."
# 2. Ejecutar lint-staged
if command -v bun >/dev/null 2>&1; then
    bun run lint-staged
else
    pnpm exec lint-staged
fi